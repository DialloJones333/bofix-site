---
// 1. COMPONENT SCRIPT (Server-side)
// Import validated JSON data
import bofixData from "../data/bofix.json";

// Destructure the services so they are easier to type
const { screenRepairs, batteryReplacement } = bofixData.services;
---

<section
  class="max-w-3xl mx-auto my-12 p-6 bg-white rounded-xl shadow-lg border border-gray-100"
>
  <h2 class="text-3xl font-extrabold text-center text-gray-900 mb-8">
    Screen Repair Prices
  </h2>

  <div class="overflow-hidden rounded-lg border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th
            scope="col"
            class="px-6 py-4 text-left text-sm font-semibold text-gray-700 uppercase tracking-wider"
            >iPhone Model</th
          >
          <th
            scope="col"
            class="px-6 py-4 text-right text-sm font-semibold text-gray-700 uppercase tracking-wider"
            >Price</th
          >
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        {
          /* Iterate over the array to generate a table row for every phone model automatically */
        }
        {
          screenRepairs.map((repair) => (
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                {repair.model}
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-blue-600 text-right">
                ${repair.price}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="mt-8 bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-lg">
    <p class="text-lg text-blue-800 font-semibold flex items-center gap-2">
      <span class="text-xl">⚡</span>
      Battery Replacement: Starting at ${batteryReplacement.startingPrice}+
    </p>
  </div>
</section>
